---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectModule from "../../components/project/ProjectModule.astro";
import { featuredProjects, getProjectBySlug } from "../../data/projects";

export function getStaticPaths() {
  return featuredProjects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const project = getProjectBySlug(Astro.params.slug ?? "");

if (!project) {
  throw new Error(`Unknown project slug: ${Astro.params.slug}`);
}
---

<BaseLayout title={`${project.title} | AJ Portfolio`}>
  <section class="case-hero">
    <div class="section-inner">
      <a class="text-link" href="/#featured-projects">Back to featured work</a>
      <div class="eyebrow">{project.tier} evidence-bound case study</div>
      <h1>{project.title}</h1>
      <p class="lead">{project.subtitle}</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner case-grid">
      <ProjectModule project={project} />
      <aside class="case-panel">
        <span class="meta-label">Publication boundary</span>
        <p>
          This page is a static shell only. It intentionally does not include fake screenshots,
          benchmark numbers, dashboards, or deployment claims beyond verified links.
        </p>
        <ul class="missing-list">
          {project.missingProof.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>
  {project.caseStudy && (
    <section class="section">
      <div class="section-inner case-study-stack">
        <div class="section-header">
          <div>
            <span class="meta-label">Evidence-bound case study</span>
            <h2>{project.title}</h2>
          </div>
          <p>
            Built from the current evidence docs and imported repo artifacts. Candidate visuals are
            real files, but remain pending until final review.
          </p>
        </div>

        <div class="case-grid">
          <article class="case-panel">
            <span class="meta-label">Problem and build</span>
            <p>{project.caseStudy.whatWasBuilt}</p>
          </article>
          <article class="case-panel">
            <span class="meta-label">Architecture</span>
            <p>{project.caseStudy.architectureSummary}</p>
          </article>
        </div>

        <div class="case-grid">
          <article class="case-panel">
            <span class="meta-label">Key engineering decisions</span>
            <ul class="missing-list">
              {project.caseStudy.engineeringDecisions.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="case-panel">
            <span class="meta-label">Proof status</span>
            <ul class="missing-list">
              {project.caseStudy.evidenceStatus.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>

        {project.visual.assets && project.visual.assets.length > 0 && (
          <article class="case-panel">
            <span class="meta-label">Visual evidence candidates</span>
            <div class="asset-grid">
              {project.visual.assets.map((asset) => (
                <figure class="asset-card">
                  <img src={asset.src} alt={asset.label} loading="lazy" />
                  <figcaption>
                    <strong>{asset.label}</strong>
                    <span>{asset.status}: {asset.note}</span>
                    <small>{asset.source}</small>
                  </figcaption>
                </figure>
              ))}
            </div>
          </article>
        )}

        {project.caseStudy.rewardProof && (
          <article class="case-panel">
            <span class="meta-label">Reward-loop proof</span>
            <ul class="missing-list">
              {project.caseStudy.rewardProof.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        )}

        {project.caseStudy.routingProof && (
          <article class="case-panel benchmark-panel">
            <span class="meta-label">{project.caseStudy.routingProof.label}</span>
            <h3>Local classifier/routing benchmark only</h3>
            <p>{project.caseStudy.routingProof.note}</p>
            <div class="table-shell" role="region" aria-label="Pending routing decision table">
              <table>
                <thead>
                  <tr>
                    {project.caseStudy.routingProof.columns.map((column) => <th>{column}</th>)}
                  </tr>
                </thead>
                <tbody>
                  {project.caseStudy.routingProof.rows.length === 0 ? (
                    <tr>
                      <td colspan={project.caseStudy.routingProof.columns.length}>
                        No benchmark examples selected yet. Latency, cost, and routing numbers remain pending.
                      </td>
                    </tr>
                  ) : (
                    project.caseStudy.routingProof.rows.map((row) => (
                      <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </article>
        )}

        {project.caseStudy.workflow && (
          <article class="case-panel">
            <span class="meta-label">Product workflow</span>
            <div class="workflow-grid">
              {project.caseStudy.workflow.map((step) => (
                <div class="workflow-step">
                  <strong>{step.label}</strong>
                  <p>{step.detail}</p>
                </div>
              ))}
            </div>
          </article>
        )}

        <div class="case-grid">
          <article class="case-panel">
            <span class="meta-label">Limitations and tradeoffs</span>
            <ul class="missing-list">
              {project.caseStudy.limitations.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="case-panel">
            <span class="meta-label">Next proof needed</span>
            <ul class="missing-list">
              {project.caseStudy.nextEvidenceNeeded.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
